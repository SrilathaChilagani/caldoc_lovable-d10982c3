    "@aws-sdk/s3-request-presigner": "^3.983.0",
    "@aws-sdk/util-format-url": "^3.936.0",
    "@daily-co/daily-js": "^0.85.0",
    "@prisma/client": "^6.19.0",
    "@sentry/nextjs": "^10.27.0",
    "@types/leaflet": "^1.9.21",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.1",
    "eas-cli": "^0.0.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "next": "^16.0.7",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "razorpay": "^2.9.6",
